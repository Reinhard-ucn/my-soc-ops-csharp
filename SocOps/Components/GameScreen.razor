@using SocOps.Models

<div class="flex flex-col min-h-full bg-gradient-to-b from-blue-800 to-blue-900">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 bg-gradient-to-r from-blue-700 to-blue-800 border-4 border-gray-900 pixel-shadow">
        <button
            @onclick="OnReset"
            class="text-white text-sm px-3 py-1.5 font-bold hover:brightness-110 transition-all active:brightness-90">
            ← BACK
        </button>
        <h1 class="font-bold text-white text-lg" style="letter-spacing: 0.05em; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-white text-sm py-2 px-4 font-bold" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.3);">
        Find matches to complete lines!
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-yellow-400 text-gray-900 text-center py-2 font-bold text-sm pixel-border border-4">
            🎮 LINE COMPLETE! Keep going!
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
