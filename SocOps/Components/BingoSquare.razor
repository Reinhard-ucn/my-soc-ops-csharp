@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-green-600 text-xs">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-2 text-center pixel-border transition-all duration-150 select-none min-h-[60px] text-xs leading-tight font-bold border-4";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-yellow-400 text-gray-900 pixel-shadow animate-block-bounce border-gray-900"
                : "bg-green-600 text-white pixel-shadow border-gray-900"
            : "bg-white text-gray-900 pixel-shadow hover:brightness-95 border-gray-900";

        var freeSpaceClasses = Square.IsFreeSpace ? "font-bold text-sm bg-blue-700 text-white border-gray-900" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
