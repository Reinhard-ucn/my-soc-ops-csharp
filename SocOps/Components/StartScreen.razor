<div class="flex flex-col items-center justify-center min-h-full p-6 bg-gradient-to-b from-blue-800 to-blue-900 relative overflow-hidden">
    <!-- Floating decorative coins -->
    <div class="absolute top-10 left-8 text-3xl animate-coin-float opacity-60" style="animation-delay: 0s;">💰</div>
    <div class="absolute top-32 right-12 text-2xl animate-coin-float opacity-60" style="animation-delay: 0.3s;">💰</div>
    <div class="absolute bottom-40 left-16 text-2xl animate-coin-float opacity-60" style="animation-delay: 0.6s;">💰</div>

    <div class="text-center max-w-lg relative z-10">
        <!-- Hero Section -->
        <div class="mb-12 animate-fade-in-down" style="animation-delay: 0.1s;">
            <h1 class="text-6xl font-bold text-white mb-2 pixel-shadow-lg" style="letter-spacing: 0.12em; line-height: 1; text-shadow: 4px 4px 8px rgba(0,0,0,0.5);">
                SOC OPS
            </h1>
            <p class="text-2xl text-yellow-300 font-bold" style="letter-spacing: 0.08em; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);">SOCIAL BINGO</p>
            <p class="text-white mt-3 font-semibold text-sm" style="letter-spacing: 0.05em; text-shadow: 1px 1px 2px rgba(0,0,0,0.3);">The Ultimate Icebreaker Game</p>
        </div>

        <!-- Features Grid -->
        <div class="grid grid-cols-1 gap-4 mb-10">
            <div class="animate-fade-in-up mario-panel mario-panel-green p-5 flex items-start gap-4" style="animation-delay: 0.3s;">
                <span class="text-3xl flex-shrink-0">👥</span>
                <div class="text-left">
                    <h3 class="font-bold mb-1 text-white" style="letter-spacing: 0.02em;">MEET NEW PEOPLE</h3>
                    <p class="text-sm text-white opacity-95">Find people matching fun prompts and make connections</p>
                </div>
            </div>

            <div class="animate-fade-in-up mario-panel mario-panel-blue p-5 flex items-start gap-4" style="animation-delay: 0.5s;">
                <span class="text-3xl flex-shrink-0">🎯</span>
                <div class="text-left">
                    <h3 class="font-bold mb-1 text-white" style="letter-spacing: 0.02em;">QUICK & FUN</h3>
                    <p class="text-sm text-white opacity-95">Get 5 in a row to win! Fast-paced social gaming at its best</p>
                </div>
            </div>

            <div class="animate-fade-in-up mario-panel mario-panel-gold p-5 flex items-start gap-4" style="animation-delay: 0.7s;">
                <span class="text-3xl flex-shrink-0">🏆</span>
                <div class="text-left">
                    <h3 class="font-bold mb-1" style="letter-spacing: 0.02em; color: #1a1a1a;">EPIC REWARDS</h3>
                    <p class="text-sm opacity-90" style="color: #1a1a1a;">Celebrate your bingo victory with style and glory</p>
                </div>
            </div>
        </div>

        <!-- Instructions Card -->
        <div class="animate-fade-in-up mario-panel mario-panel-red p-6 mb-10" style="animation-delay: 0.9s;">
            <h2 class="font-bold text-lg mb-4 text-white" style="letter-spacing: 0.1em;">HOW TO PLAY</h2>
            <div class="space-y-3 text-sm text-left">
                <div class="flex gap-3 items-start">
                    <span class="text-xl flex-shrink-0">1️⃣</span>
                    <p class="text-white">Read the prompt on each square</p>
                </div>
                <div class="flex gap-3 items-start">
                    <span class="text-xl flex-shrink-0">2️⃣</span>
                    <p class="text-white">Find someone who matches the description</p>
                </div>
                <div class="flex gap-3 items-start">
                    <span class="text-xl flex-shrink-0">3️⃣</span>
                    <p class="text-white">Tap the square when you find them</p>
                </div>
                <div class="flex gap-3 items-start">
                    <span class="text-xl flex-shrink-0">4️⃣</span>
                    <p class="text-white">Get 5 in a row (horizontal, vertical, or diagonal)</p>
                </div>
                <div class="flex gap-3 items-start">
                    <span class="text-xl flex-shrink-0">5️⃣</span>
                    <p class="text-white"><strong>WIN!</strong> 🎉</p>
                </div>
            </div>
        </div>

        <!-- Mode Selection Buttons -->
        <div class="flex gap-4 w-full animate-fade-in-up" style="animation-delay: 1.1s;">
            <button
                @onclick="OnStartBingo"
                class="flex-1 bg-red-600 text-white font-bold py-5 px-6 mario-btn text-lg animate-fade-in-up border-4 border-gray-900 hover:bg-red-700"
                style="letter-spacing: 0.1em;">
                🎮 BINGO 🎮
            </button>
            <button
                @onclick="OnStartScavengerHunt"
                class="flex-1 bg-blue-600 text-white font-bold py-5 px-6 mario-btn text-lg animate-fade-in-up border-4 border-gray-900 hover:bg-blue-700"
                style="letter-spacing: 0.1em; animation-delay: 0.1s;">
                🔍 HUNT 🔍
            </button>
        </div>

        <!-- Social Proof / Tagline -->
        <p class="text-white text-xs mt-6 font-semibold animate-fade-in opacity-80" style="animation-delay: 1.3s; letter-spacing: 0.02em; text-shadow: 1px 1px 2px rgba(0,0,0,0.3);">
            Ready to break the ice? Let's go! ⭐
        </p>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }

    [Parameter]
    public EventCallback OnStartScavengerHunt { get; set; }

    private async Task OnStartBingo()
    {
        await OnStart.InvokeAsync();
    }
}
